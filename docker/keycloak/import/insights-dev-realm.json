{
  "id": "insights-dev",
  "realm": "insights-dev",
  "displayName": "Insights Platform (dev)",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "accessCodeLifespan": 60,
  "clients": [
    {
      "clientId": "insights-web",
      "name": "Insights Web (public, Direct Access Grant)",
      "description": "Usado pelo backend em keycloak-sign-in (grant_type=password).",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "redirectUris": ["http://localhost:3000/*", "http://127.0.0.1:3000/*"],
      "webOrigins": ["http://localhost:3000", "http://127.0.0.1:3000"],
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access"]
    }
  ],
  "users": [
    {
      "username": "dev@example.com",
      "enabled": true,
      "emailVerified": true,
      "email": "dev@example.com",
      "firstName": "Dev",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "DevPass123!",
          "temporary": false
        }
      ]
    }
  ]
}
