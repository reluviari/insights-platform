# Insights Platform — variáveis para Docker Compose na raiz do repositório
# Copie para ".env" na raiz (mesmo nível que docker-compose.yml):
#   cp .env.docker.example .env
#
# --- API (Docker / serverless-offline) ---
MONGODB_URI=mongodb://mongo:27017/qa-pbi
SITE_URL=http://localhost:3000
# Keycloak: NÃO USAR por agora — deixe vazio. Reservado para eventual SSO futuro (ver docker/KEYCLOAK.md).
KEYCLOAK_URL=

# Evita erro se o módulo S3 for carregado (credenciais não precisam ser válidas para dev sem upload).
INSIGHTS_ADMIN_CREDENTIALS=placeholder_access;placeholder_secret

# Silencia o aviso de maintenance mode do aws-sdk v2 nos logs locais (não dispensa migração futura para @aws-sdk/*).
AWS_SDK_JS_SUPPRESS_MAINTENANCE_MODE_MESSAGE=1

# Opcional: logs extra na API no fluxo sign-in (utilizador não encontrado vs senha/hash).
# INSIGHTS_DEBUG_SIGN_IN=1

# --- Microsoft Power BI / Azure AD (sempre externos; obrigatório para embed e tokens reais) ---
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET_VALUE=
AZURE_TENANT_ID=
AZURE_USERNAME=
AZURE_PASSWORD=
EMBED_PBI_API_URL=https://api.powerbi.com

# --- Web (Next.js) ---
NEXT_PUBLIC_INSIGHTS_API=http://localhost:4001
NEXT_PUBLIC_EMBED_PBI_APP_URL=https://app.powerbi.com
NEXT_PUBLIC_PLATAFORM_NAME=Insights
# SSO (Keycloak): NÃO USAR por agora — mantenha false. Roadmap futuro (docker/KEYCLOAK.md).
NEXT_PUBLIC_INSIGHTS_SSO_ENABLED=false
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-only-change-me
