#!/bin/sh
# Remove trailers "Co-authored-by: Cursor" (cursoragent@cursor.com) do Cursor IDE.
msg_file=$1
[ -n "$msg_file" ] && [ -f "$msg_file" ] || exit 0
tmp=$(mktemp) || exit 0
sed -e '/^Co-authored-by: Cursor <cursoragent@cursor\.com>$/d' \
    -e '/^Co-authored-by:.*cursoragent@cursor\.com$/d' \
    "$msg_file" > "$tmp" && cat "$tmp" > "$msg_file" && rm -f "$tmp"
exit 0
