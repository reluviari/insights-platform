{
  "name": "insights-platform-api",
  "version": "1.0.0",
  "description": "Insights Platform — API serverless AWS (Lambda + API Gateway)",
  "main": "serverless.ts",
  "scripts": {
    "dev:local": "ts-node-dev -r tsconfig-paths/register  server.ts",
    "build": "tsc",
    "local-swagger": "node localSwagger.js",
    "dev": "sls offline start --reloadHandler",
    "test": "jest",
    "test-coverage": "jest --coverage",
    "lint": "npx eslint 'src/**'",
    "seed:mongo:keycloak": "mongosh \"${MONGODB_URI:-mongodb://127.0.0.1:27017/qa-pbi}\" --file ../docker/mongo/seed-insights-keycloak-dev.js"
  },
  "engines": {
    "node": ">=14.15.0"
  },
  "dependencies": {
    "@middy/core": "^4.5.2",
    "@middy/http-error-handler": "^4.5.2",
    "@middy/http-json-body-parser": "^4.5.2",
    "@types/bcryptjs": "^2.4.2",
    "aws-sdk": "^2.1438.0",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "fastify": "^4.27.0",
    "jsonwebtoken": "^9.0.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "mongoose": "^7.3.1",
    "path-to-regexp": "^6.2.1",
    "reflect-metadata": "^0.1.13",
    "ts-node-dev": "^2.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@serverless/eslint-config": "^5.1.0",
    "@serverless/typescript": "^3.30.1",
    "@types/aws-lambda": "^8.10.119",
    "@types/aws-sdk": "^2.7.0",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.3.1",
    "@typescript-eslint/eslint-plugin": "^5.60.1",
    "@typescript-eslint/parser": "^5.60.1",
    "dotenv": "^16.3.1",
    "esbuild": "^0.14.11",
    "eslint": "^8.43.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^4.2.1",
    "fs": "^0.0.1-security",
    "jest": "^29.5.0",
    "jest-module-name-mapper": "^0.1.5",
    "json-schema-to-ts": "^2.9.1",
    "mock-aws-s3": "^4.0.2",
    "nock": "^13.3.1",
    "path": "^0.12.7",
    "prettier": "^2.8.8",
    "serverless": "^3.32.2",
    "serverless-aws-documentation": "^1.1.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-esbuild": "^1.43.0",
    "serverless-offline": "^12.0.4",
    "swagger-ui-express": "^4.6.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-jest": "^0.0.1",
    "typescript": "^5.1.0"
  },
  "eslintConfig": {
    "extends": "@serverless/eslint-config/node",
    "root": true
  },
  "author": "The serverless webpack authors (https://github.com/elastic-coders/serverless-webpack)",
  "license": "MIT"
}
